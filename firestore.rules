rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validCommentCreate() {
      return request.resource.data.keys().hasOnly([
          'name',
          'rating',
          'comment',
          'status',
          'createdAt',
          'approvedAt',
          'rejectedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 40
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() >= 1
        && request.resource.data.comment.size() <= 240
        && request.resource.data.status == 'pending';
    }

    function validPhotoCreate() {
      return request.resource.data.keys().hasOnly([
          'name',
          'caption',
          'imageUrl',
          'publicId',
          'cloudinaryAssetId',
          'width',
          'height',
          'status',
          'createdAt',
          'approvedAt',
          'rejectedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 40
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 160
        && request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.matches('https://res.cloudinary.com/.*')
        && request.resource.data.publicId is string
        && request.resource.data.publicId.size() >= 1
        && request.resource.data.cloudinaryAssetId is string
        && request.resource.data.status == 'pending';
    }

    match /admins/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, create, update, delete: if false;
    }

    match /comments/{commentId} {
      allow create: if validCommentCreate();
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow create: if validPhotoCreate();
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
